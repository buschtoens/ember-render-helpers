{
  "name": "workspace-root",
  "version": "1.0.6",
  "private": true,
  "repository": "",
  "license": "MIT",
  "author": "",
  "scripts": {
    "build": "pnpm --filter \"./packages/**\" build",
    "lint": "pnpm --filter \"*\" lint",
    "lint:fix": "pnpm --filter \"*\" lint:fix",
    "prepare": "pnpm build",
    "release:prepare": "changeset version; update-workspace-root-version",
    "release:publish": "pnpm build && changeset publish",
    "start": "concurrently \"pnpm:start:*\" --restart-after 5000 --prefix-colors cyan,yellow",
    "start:addon": "pnpm --filter ember-render-helpers start",
    "start:test-app": "pnpm --filter test-app start",
    "test": "pnpm --filter \"*\" test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@changesets/get-github-info": "^0.6.0",
    "concurrently": "^9.2.1",
    "update-workspace-root-version": "^2.0.4"
  },
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": "18.* || >= 20",
    "pnpm": ">= 10"
  },
  "pnpm": {
    "overrides": {
      "get-tsconfig": "4.7.3"
    }
  }
}
