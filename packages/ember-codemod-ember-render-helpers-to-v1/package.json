{
  "name": "ember-codemod-ember-render-helpers-to-v1",
  "version": "2.0.0",
  "description": "Rename helpers from ember-render-helpers",
  "keywords": [
    "codemod",
    "ember-codemod",
    "emberjs"
  ],
  "repository": "buschtoens/ember-render-helpers",
  "license": "MIT",
  "author": "Isaac J. Lee",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": "dist/bin/ember-codemod-ember-render-helpers-to-v1.js",
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "./build.sh --production",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "tsc --noEmit",
    "prepare": "pnpm build",
    "test": "./build.sh --test && mt dist-for-testing --quiet"
  },
  "dependencies": {
    "@codemod-utils/ast-template": "^2.0.3",
    "@codemod-utils/files": "^3.0.5",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@codemod-utils/tests": "^2.0.4",
    "@ijlee2-frontend-configs/eslint-config-node": "^3.3.0",
    "@ijlee2-frontend-configs/prettier": "^3.1.0",
    "@sondr3/minitest": "^0.1.2",
    "@tsconfig/node20": "^20.1.9",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^20.19.39",
    "@types/yargs": "^17.0.35",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "20.* || >= 22"
  }
}
