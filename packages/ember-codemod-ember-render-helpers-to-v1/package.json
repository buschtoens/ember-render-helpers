{
  "name": "ember-codemod-ember-render-helpers-to-v1",
  "version": "1.0.4",
  "description": "Rename helpers from ember-render-helpers",
  "keywords": [
    "codemod",
    "ember-codemod",
    "emberjs"
  ],
  "repository": "buschtoens/ember-render-helpers",
  "license": "MIT",
  "author": "Isaac J. Lee",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": "dist/bin/ember-codemod-ember-render-helpers-to-v1.js",
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "./build.sh --production",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\"",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "tsc --noEmit",
    "prepare": "pnpm build",
    "test": "./build.sh --test && mt dist-for-testing --quiet"
  },
  "dependencies": {
    "@codemod-utils/ast-template": "^2.0.3",
    "@codemod-utils/files": "^3.0.5",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@codemod-utils/tests": "^2.0.4",
    "@ijlee2-frontend-configs/eslint-config-node": "^2.1.2",
    "@ijlee2-frontend-configs/prettier": "^2.1.1",
    "@sondr3/minitest": "^0.1.2",
    "@tsconfig/node18": "^18.2.4",
    "@tsconfig/strictest": "^2.0.5",
    "@types/node": "^18.19.124",
    "@types/yargs": "^17.0.33",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": "18.* || >= 20"
  }
}
